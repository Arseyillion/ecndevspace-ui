{
  "name": "ecndevspace-ui",
  "version": "0.1.0",
  "type": "module",
   "description": "This is a react component library built by Emmanuel Chukwuemeka Nwuju for EcnDevSpace. It contains a collection of reusable React components that can be used to build user interfaces.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "jest --watchAll --verbose",
    "test:ci": "jest --runInBand --verbose",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky",
    "lint": "eslint ./src/ --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint ./src --fix"
  },
  "jest": {
    "testEnvironment": "jsdom"
  },
  "babel": {
    "sourceType": "unambiguous",
    "presets": [
      "@babel/preset-env",
      "@babel/preset-typescript",
      [
        "@babel/preset-react",
        {
          "runtime": "automatic"
        }
      ]
    ]
  },
  "dependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Arseyillion/my-component-library.git"
  },
  "author": "Emmanuel Chukwuemeka Nwuju",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Arseyillion/my-component-library/issues"
  },
  "homepage": "https://github.com/Arseyillion/my-component-library#readme",
  "devDependencies": {
    "@babel/preset-env": "^8.0.2",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/jest": "^30.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jiti": "^2.7.0",
    "playwright": "^1.61.1",
    "rollup": "^4.62.2",
    "rollup-plugin-dts": "^6.4.1",
    "rollup-plugin-postcss": "^4.0.2",
    "standard-version": "^9.5.0",
    "storybook": "^10.4.6",
    "styled-components": "^6.4.3",
    "tslib": "^2.8.1",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
